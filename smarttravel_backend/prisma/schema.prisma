// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Location {
  id      String  @id @default(uuid()) @db.Uuid
  country String
  city    String
  state   String?

  addresses Address[]
  airports  Airport[]
  offers    Offer[]

  @@unique([country, city])
}

model Address {
  id          String @id @default(uuid()) @db.Uuid
  street      String
  houseNumber String
  postalCode  String

  locationId String   @db.Uuid
  location   Location @relation(fields: [locationId], references: [id])

  accommodations Accommodation[]
}

model Flight {
  id            String   @id @default(uuid()) @db.Uuid
  airlineName   String
  flightNumber  String
  departureTime DateTime
  arrivalTime   DateTime
  price         Float
  currency      String

  fromIataCode String
  toIataCode   String

  from Airport @relation("FromAirport", fields: [fromIataCode], references: [iataCode])
  to   Airport @relation("ToAirport", fields: [toIataCode], references: [iataCode])

  outboundOffers Offer[] @relation("OutboundFlight")
  returnOffers   Offer[] @relation("ReturnFlight")
}

model Airport {
  iataCode String @id
  name     String

  departures Flight[] @relation("FromAirport")
  arrivals   Flight[] @relation("ToAirport")

  locationId String   @db.Uuid
  location   Location @relation(fields: [locationId], references: [id])
}

model Accommodation {
  id           String @id @default(uuid()) @db.Uuid
  name         String
  nights       Int
  costPerNight Float
  currency     String

  addressId String  @db.Uuid
  address   Address @relation(fields: [addressId], references: [id])

  offers Offer[]
}

model Offer {
  id          String   @id @default(uuid()) @db.Uuid
  description String?
  fee         Float
  currency    String
  createdAt   DateTime @default(now())

  locationId       String @db.Uuid
  accommodationId  String @db.Uuid
  outboundFlightId String @db.Uuid
  returnFlightId   String @db.Uuid

  outboundFlight Flight        @relation("OutboundFlight", fields: [outboundFlightId], references: [id])
  returnFlight   Flight        @relation("ReturnFlight", fields: [returnFlightId], references: [id])
  location       Location      @relation(fields: [locationId], references: [id])
  accommodation  Accommodation @relation(fields: [accommodationId], references: [id])
}
